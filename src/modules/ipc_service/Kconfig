menuconfig THREAD_IPC_SERVICE
	bool "Thread IPC service (in-app request/response)"
	default n
	help
	  In-application thread-based IPC: worker thread + dispatcher thread,
	  message queues, sync / async / future call modes.

	  Note: This is NOT Zephyr's subsys IPC Service (RPMSG/icmsg backends).
	  Name THREAD_IPC_SERVICE avoids Kconfig symbol collision with upstream
	  CONFIG_IPC_SERVICE.

if THREAD_IPC_SERVICE

config THREAD_IPC_SERVICE_MAX_PENDING_REQUESTS
    int "Maximum pending requests"
    default 16
    range 4 64
    help
      Maximum number of pending requests that can be tracked at any time.

config THREAD_IPC_SERVICE_REQUEST_QUEUE_SIZE
    int "Request queue depth"
    default 8
    range 2 32
    help
      Number of request messages the worker queue can hold (static buffer).

config THREAD_IPC_SERVICE_RESPONSE_QUEUE_SIZE
    int "Response queue depth"
    default 8
    range 2 32
    help
      Number of response messages the dispatcher queue can hold (static buffer).

config THREAD_IPC_SERVICE_STACK_SIZE
    int "Per-thread stack size (worker + dispatcher)"
    default 2048
    range 512 8192
    help
      Stack size in bytes for each of the two internal threads (embedded in
      ipc_service_t). No kernel heap is required.

config THREAD_IPC_SERVICE_PRIORITY
    int "Thread priority (worker and dispatcher)"
    default 5
    range -16 15
    help
      Priority for worker and dispatcher threads.

config THREAD_IPC_SERVICE_LOG_LEVEL
    int "Log level"
    default 3
    range 0 4
    help
      0=OFF, 1=ERROR, 2=WARNING, 3=INFO, 4=DEBUG

config THREAD_IPC_SERVICE_EXAMPLE
    bool "Build thread IPC example"
    default n
    depends on THREAD_IPC_SERVICE
    help
      Example SYS_INIT + demo thread (sync/async/future).

config THREAD_IPC_SERVICE_EVENT_BRIDGE
    bool "Bridge: publish IPC results to event system"
    default n
    depends on THREAD_IPC_SERVICE && EVENT_SYSTEM
    help
      Provides ipc_service_event.h/c: register event type THREAD_IPC_EVENT_TYPE_RESPONSE
      and thread_ipc_event_publish_result() for use inside ipc_service_func_t.

config THREAD_IPC_SERVICE_SHARED_MEM
    bool "Shared memory pool with reference counting"
    default y
    depends on THREAD_IPC_SERVICE
    help
      Enable shared memory pool with automatic reference counting for safe
      cross-thread data transfer. Solves:
      1. Unclear ownership - service function returned data lifecycle is unclear
      2. No reference counting - caller must guarantee buffer validity
      3. No safe sharing mechanism - no protection for cross-thread data

config THREAD_IPC_SERVICE_SHARED_MEM_POOL_SIZE
    int "Shared memory pool block count"
    default 32
    range 8 128
    depends on THREAD_IPC_SERVICE_SHARED_MEM
    help
      Number of shared memory blocks in the static pool.

config THREAD_IPC_SERVICE_SHARED_MEM_BLOCK_SIZE
    int "Shared memory block size (bytes)"
    default 512
    range 64 4096
    depends on THREAD_IPC_SERVICE_SHARED_MEM
    help
      Size of each shared memory block in bytes.

config THREAD_IPC_SERVICE_SHARED_MEM_LOG_LEVEL
    int "Shared memory log level"
    default 3
    range 0 4
    depends on THREAD_IPC_SERVICE_SHARED_MEM
    help
      0=OFF, 1=ERROR, 2=WARNING, 3=INFO, 4=DEBUG

config EXAMPLE_MODULE_THREAD_IPC
    bool "Example: business module integrating Thread IPC (module_manager)"
    default n
    depends on THREAD_IPC_SERVICE && MODULE_MANAGER
    help
      Builds example_module_ipc.c: registers with module_manager, ipc_service in
      init/start/stop, optional demo thread calling ipc_call_sync.

endif # THREAD_IPC_SERVICE
